---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: string;
  breadcrumbs?: Array<{ label: string; href?: string }>;
  schema?: object;
}

const { title, description, canonical, image, type, breadcrumbs, schema } = Astro.props;
---

<BaseLayout title={title} description={description} canonical={canonical} image={image} type={type}>
  <Fragment slot="head">
    {breadcrumbs && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": breadcrumbs.map((item, index) => ({
          "@type": "ListItem",
          "position": index + 1,
          "name": item.label,
          ...(item.href ? { "item": `https://dayboi.vip${item.href}` } : {}),
        })),
      })} />
    )}
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
  </Fragment>

  <Header slot="header" />

  <!-- Breadcrumb -->
  {breadcrumbs && breadcrumbs.length > 0 && (
    <nav class="breadcrumb" aria-label="Breadcrumb" style={`padding-top: calc(var(--header-height) + var(--space-4)); background: var(--color-bg-alt);`}>
      <div class="container container-wide">
        <ol class="breadcrumb-list">
          {breadcrumbs.map((item, index) => (
            <li class="breadcrumb-item">
              {index > 0 && <span class="breadcrumb-separator">›</span>}
              {item.href ? (
                <a href={item.href}>{item.label}</a>
              ) : (
                <span>{item.label}</span>
              )}
            </li>
          ))}
        </ol>
      </div>
    </nav>
  )}

  <slot />

  <Footer slot="footer" />
</BaseLayout>
