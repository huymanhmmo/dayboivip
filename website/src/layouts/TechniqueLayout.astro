          ))}
        </div>
      </div>
    </section>

    <!-- Floating CTA Mobile -->
    <div class="tl-floating-cta">
      <div class="tl-floating-cta-inner">
        <a href="tel:0979121097" class="tl-btn tl-btn--accent">📞 Gọi Hotline</a>
        <a href="https://zalo.me/0979121097" target="_blank" rel="noopener noreferrer" class="tl-btn tl-btn--outline" style="color: #0077B6; border-color: #0077B6;">💬 Chat Zalo</a>
      </div>
    </div>
