    </section>

    <!-- Registration Form Block -->
    <section class="tl-section tl-section--alt" id="dang-ky">
      <div class="tl-section__container">
        <div class="tl-section-title">
          <span class="tl-section-title__badge">Đăng ký học bơi</span>
          <h2 class="tl-section-title__heading">Luyện Tập Cùng Huấn Luyện Viên Chuyên Nghiệp</h2>
          <p class="tl-section-title__sub">
            Đăng ký học thử 1 buổi MIỄN PHÍ cùng HLV 1 kèm 1 tại Swim For Life Việt Nam để chỉnh sửa lỗi kỹ thuật bơi chuẩn nhất.
          </p>
          <span class="tl-section-title__decoration"></span>
        </div>

        <div class="tl-form-container">
          <div class="tl-form-info">
            <h3 class="tl-form-info__title">Swim For Life Việt Nam</h3>
            <p class="tl-form-info__text">
              Chúng tôi cam kết 100% học viên biết bơi sau khóa học 10-12 buổi. HLV kèm riêng tận tâm dưới nước, giáo án cá nhân hóa theo thể trạng từng học viên.
            </p>
            <div class="tl-form-info__links">
              <a href="tel:0979121097" class="tl-form-info__link">
                <span class="tl-form-info__icon">📞</span>
                <div>
                  <span class="tl-form-info__label">Hotline / Zalo tư vấn</span>
                  <span class="tl-form-info__value">0979.121.097</span>
                </div>
              </a>
              <a href="https://zalo.me/0979121097" target="_blank" rel="noopener noreferrer" class="tl-form-info__link">
                <span class="tl-form-info__icon">💬</span>
                <div>
                  <span class="tl-form-info__label">Trò chuyện qua Zalo</span>
                  <span class="tl-form-info__value">Mr.Mạnh (0979.121.097)</span>
                </div>
              </a>
            </div>
          </div>
          
          <div class="tl-form-wrapper">
            <RegistrationForm id="technique-register-form" className="tl-astro-form" />
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Accordion -->
    {faqs && faqs.length > 0 && (
      <section class="tl-section" id="faq">
        <div class="tl-section__container">
          <div class="tl-section-title">
            <span class="tl-section-title__badge">Giải đáp thắc mắc</span>
            <h2 class="tl-section-title__heading">Câu Hỏi Thường Gặp</h2>
            <p class="tl-section-title__sub">
              Trả lời các câu hỏi phổ biến của học viên về việc tập luyện kỹ thuật {technique.name}.
            </p>
            <span class="tl-section-title__decoration"></span>
          </div>

          <div class="tl-faq">
            {faqs.map(faq => (
              <div class="tl-faq__item">
                <button class="tl-faq__question" aria-expanded="false">
                  <span>{faq.question}</span>
                  <span class="tl-faq__icon">+</span>
                </button>
                <div class="tl-faq__answer">
                  <div class="tl-faq__answer-inner">
                    <p>{faq.answer}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Cross-Linking / Other Techniques Section -->
    <section class="tl-section tl-section--alt">
      <div class="tl-section__container">
        <div class="tl-section-title">
          <span class="tl-section-title__badge">Liên kết kỹ thuật</span>
          <h2 class="tl-section-title__heading">Khám Phá Các Kỹ Thuật Bơi Khác</h2>
          <p class="tl-section-title__sub">
            Nâng cao kỹ năng bơi lội của bạn bằng cách làm chủ các kiểu bơi thể thao và kỹ năng sinh tồn hữu ích khác.
          </p>
