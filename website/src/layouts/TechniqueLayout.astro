        </div>

        <div class="tl-cross-grid">
          {otherTechniques.map(t => (
            <a href={t.link} class="tl-cross-card">
              <span class="tl-cross-card__icon">{t.icon}</span>
              <h3 class="tl-cross-card__title">{t.name}</h3>
              <p class="tl-cross-card__desc">{t.desc}</p>
              <span class="tl-cross-card__link">Xem hướng dẫn →</span>
