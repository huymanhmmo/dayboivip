</PageLayout>

<script>
  // FAQ Accordion Toggle
  const setupFAQ = () => {
    const faqItems = document.querySelectorAll('.tl-faq__item');
    faqItems.forEach(item => {
      const button = item.querySelector('.tl-faq__question');
      if (button) {
        button.addEventListener('click', () => {
          const isActive = item.classList.contains('active');
          
          // Close all
          faqItems.forEach(i => {
            i.classList.remove('active');
            i.querySelector('.tl-faq__question')?.setAttribute('aria-expanded', 'false');
          });
          
          if (!isActive) {
            item.classList.add('active');
            button.setAttribute('aria-expanded', 'true');
          }
        });
      }
    });
  };

  // Sticky TOC highlighting on scroll & dynamic layout scroll margins
  const setupTOC = () => {
    const sections = document.querySelectorAll('article.tl-prose section[id], section#loi-thuong-gap, section#faq');
    const tocLinks = document.querySelectorAll('.tl-toc-link');
    
    if (sections.length === 0 || tocLinks.length === 0) return;

    // Apply scroll margin dynamically for sticky elements offset
    const updateScrollMargin = () => {
      const isDesktop = window.innerWidth >= 1024;
      sections.forEach(sec => {
        (sec as HTMLElement).style.scrollMarginTop = isDesktop ? '90px' : '140px';
      });
    };

    updateScrollMargin();
    window.addEventListener('resize', updateScrollMargin);

    window.addEventListener('scroll', () => {
      let currentSectionId = '';
      const isDesktop = window.innerWidth >= 1024;
      const scrollPosition = window.scrollY + (isDesktop ? 110 : 180); // Offset for header + TOC bar

      sections.forEach(section => {
        const top = (section as HTMLElement).offsetTop;
        const height = (section as HTMLElement).offsetHeight;
        if (scrollPosition >= top && scrollPosition < top + height) {
          currentSectionId = section.getAttribute('id') || '';
        }
      });

      if (currentSectionId) {
        tocLinks.forEach(link => {
          link.classList.remove('active');
          if (link.getAttribute('href') === `#${currentSectionId}`) {
            link.classList.add('active');
            
            // Scroll the TOC bar horizontally to keep active link visible on mobile
            const nav = document.querySelector('.tl-toc-nav');
            if (nav) {
              const linkOffsetLeft = (link as HTMLElement).offsetLeft;
              const linkWidth = (link as HTMLElement).offsetWidth;
              const navScrollLeft = nav.scrollLeft;
              const navWidth = nav.clientWidth;
              
              if (linkOffsetLeft < navScrollLeft) {
                nav.scrollTo({ left: linkOffsetLeft - 20, behavior: 'smooth' });
              } else if (linkOffsetLeft + linkWidth > navScrollLeft + navWidth) {
                nav.scrollTo({ left: linkOffsetLeft - navWidth + linkWidth + 20, behavior: 'smooth' });
              }
            }
          }
        });
      }
    });
  };

  // Reading Progress Indicator
  const setupReadingProgress = () => {
    const progressBar = document.getElementById('reading-progress');
    if (!progressBar) return;
    
    const updateProgress = () => {
      const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      if (scrollHeight <= 0) return;
      const scrollPosition = window.scrollY;
      const progressPercent = Math.min(100, Math.max(0, (scrollPosition / scrollHeight) * 100));
      progressBar.style.width = `${progressPercent}%`;
    };
    
    window.addEventListener('scroll', updateProgress);
    window.addEventListener('resize', updateProgress);
    updateProgress();
  };

  // Swimmer Anatomy Interactive Widget
  const setupAnatomyWidget = () => {
    const scriptEl = document.getElementById('anatomy-data-script');
    if (!scriptEl) return;
    
    let data: any;
    try {
      data = JSON.parse(scriptEl.textContent || '{}');
    } catch (e) {
      console.error("Failed to parse anatomy data", e);
      return;
    }
    
    const hotspots = document.querySelectorAll('.tl-anatomy__hotspot');
    const selectBtns = document.querySelectorAll('.tl-anatomy__select-btn');
    
    const iconEl = document.getElementById('anatomy-icon');
    const titleEl = document.getElementById('anatomy-title');
    const subtitleEl = document.getElementById('anatomy-subtitle');
    const descEl = document.getElementById('anatomy-desc');
    
    if (!iconEl || !titleEl || !subtitleEl || !descEl) return;
    
    const updateDisplay = (part: string) => {
      const partData = data[part];
      if (!partData) return;
      
      // Update text with transition effect
      const card = document.querySelector('.tl-anatomy__card');
      if (card) {
        card.classList.add('tl-updating');
        setTimeout(() => {
          iconEl.textContent = partData.icon || '💡';
          titleEl.textContent = partData.title || '';
          subtitleEl.textContent = partData.subtitle || '';
          descEl.textContent = partData.desc || '';
          card.classList.remove('tl-updating');
        }, 150);
      } else {
        iconEl.textContent = partData.icon || '💡';
        titleEl.textContent = partData.title || '';
        subtitleEl.textContent = partData.subtitle || '';
        descEl.textContent = partData.desc || '';
      }
      
      // Update hotspots active state
      hotspots.forEach(h => {
        if (h.getAttribute('data-part') === part) {
          h.classList.add('active');
        } else {
          h.classList.remove('active');
        }
      });
      
      // Update selector buttons active state
      selectBtns.forEach(b => {
        if (b.getAttribute('data-part') === part) {
          b.classList.add('active');
        } else {
          b.classList.remove('active');
        }
      });
    };
    
    // Add event listeners for hotspots
    hotspots.forEach(h => {
      const part = h.getAttribute('data-part');
      if (!part) return;
      
      h.addEventListener('click', (e) => {
        e.preventDefault();
        updateDisplay(part);
      });
      
      h.addEventListener('mouseenter', () => {
        updateDisplay(part);
      });
    });
    
    // Add event listeners for selection buttons (mobile selectors)
    selectBtns.forEach(b => {
      const part = b.getAttribute('data-part');
      if (!part) return;
      
      b.addEventListener('click', (e) => {
        e.preventDefault();
        updateDisplay(part);
      });
    });
  };

  // Run immediately and on DOMContentLoaded
  setupFAQ();
  setupTOC();
  setupReadingProgress();
  setupAnatomyWidget();
  
  document.addEventListener('DOMContentLoaded', () => {
    setupFAQ();
    setupTOC();
    setupReadingProgress();
    setupAnatomyWidget();
  });
</script>
