---
import PageLayout from './PageLayout.astro';
import YouTubeVideo from '../components/YouTubeVideo.astro';
import RegistrationForm from '../components/RegistrationForm.astro';
import { blogPosts } from '../data/blogPosts.js';

import '../styles/technique-landing.css';

export interface Props {
  metadata: {
    title: string;
    description: string;
    canonical: string;
    image?: string;
    breadcrumbs: Array<{ label: string; href?: string }>;
    articleSchema?: any;
    faqSchema?: any;
    howToSchema?: any;
  };
  technique: {
    slug: string;
    name: string;
    badge: string;
    description: string;
    difficulty: 'Cơ bản' | 'Trung bình' | 'Nâng cao' | 'Sinh tồn';
    speed: 'Chậm' | 'Trung bình' | 'Nhanh' | 'Rất nhanh';
    calories: string;
    muscles: string;
    videoId: string;
    videoPoster: string;
    videoAlt: string;
  };
  toc: Array<{ id: string; label: string }>;
  errors: Array<{
    title: string;
    problem: string;
    solution: string;
  }>;
  faqs: Array<{
    question: string;
    answer: string;
  }>;
  relatedKeywords: string[];
}

const { metadata, technique, toc, errors, faqs, relatedKeywords } = Astro.props;

// Lọc bài viết liên quan dựa trên từ khóa
const relatedPosts = blogPosts.filter(post => {
  return relatedKeywords.some(keyword => {
    const kw = keyword.toLowerCase();
    const inTitle = post.title.toLowerCase().includes(kw);
    const inExcerpt = post.excerpt.toLowerCase().includes(kw);
    const inTags = post.tags && post.tags.some(tag => tag.toLowerCase().includes(kw));
    return inTitle || inExcerpt || inTags;
  });
}).slice(0, 3);

// Nếu không có bài viết liên quan, lấy 3 bài viết mặc định mới nhất
const displayPosts = relatedPosts.length > 0 ? relatedPosts : blogPosts.slice(0, 3);

// Dữ liệu cho các kỹ thuật bơi lội khác để liên kết chéo
const allTechniques = [
  { slug: 'hoc-boi-ech', name: 'Học Bơi Ếch', icon: '🐸', desc: 'Kiểu bơi cơ bản nhất, dễ học, nền tảng sinh tồn hàng đầu.', link: '/ky-thuat-boi/hoc-boi-ech/' },
  { slug: 'hoc-boi-sai', name: 'Học Bơi Sải', icon: '🏊', desc: 'Kiểu bơi nhanh nhất, tăng sức bền và phát triển thể lực toàn diện.', link: '/ky-thuat-boi/hoc-boi-sai/' },
  { slug: 'hoc-boi-ngua', name: 'Học Bơi Ngửa', icon: '🤽', desc: 'Kiểu bơi thư giãn nhất, dễ thở, giúp kéo giãn cột sống tự nhiên.', link: '/ky-thuat-boi/hoc-boi-ngua/' },
  { slug: 'hoc-boi-buom', name: 'Học Bơi Bướm', icon: '🦋', desc: 'Kiểu bơi đẹp mắt, mạnh mẽ nhất, uốn sóng cá heo độc đáo.', link: '/ky-thuat-boi/hoc-boi-buom/' },
  { slug: 'ky-nang-dung-nuoc', name: 'Kỹ Năng Đứng Nước', icon: '🛟', desc: 'Kỹ năng sinh tồn cốt lõi giúp tự nổi tại chỗ không mất sức.', link: '/ky-thuat-boi/ky-nang-dung-nuoc/' }
];

const otherTechniques = allTechniques.filter(t => t.slug !== technique.slug);

// Helpers cho hiển thị Specs Dashboard V2
const difficultyLevels = ['Sinh tồn', 'Cơ bản', 'Trung bình', 'Nâng cao'];
const diffIndex = difficultyLevels.indexOf(technique.difficulty);
const diffOffset = 213.6 - (Math.max(0, diffIndex) / 3) * 213.6;

const speedLevels = ['Chậm', 'Trung bình', 'Nhanh', 'Rất nhanh'];
const speedIndex = speedLevels.indexOf(technique.speed);
const speedOffset = 213.6 - (Math.max(0, speedIndex) / 3) * 213.6;

const calVal = parseInt(technique.calories.replace(/[^0-9]/g, '')) || 600;
const calOffset = 213.6 - (Math.min(1000, calVal) / 1000) * 213.6;

const musclesList = technique.muscles.split(',').map(m => m.trim());

// Dữ liệu cho Swimmer Anatomy Widget
const anatomyData = {
  'hoc-boi-ech': {
    head: { title: 'Tư thế Đầu & Thở', subtitle: 'Hít thở nhịp nhàng', desc: 'Đầu giữ thẳng trục với cột sống khi lướt nước. Khi nhô lên lấy hơi, chỉ nâng cằm vừa đủ khỏi mặt nước, mắt nhìn chéo xuống dưới góc 45 độ để tránh đau cổ và giữ thăng bằng.', icon: '🗣️' },
    arms: { title: 'Động tác Tay', subtitle: 'Quạt nước hình trái tim', desc: 'Tỳ nước rộng bằng vai, quạt chéo xuống dưới và hướng ra sau vẽ hình trái tim. Khép cùi chỏ sát sườn trước ngực rồi duỗi thẳng tay ngay lập tức để giảm lực cản.', icon: '👐' },
    core: { title: 'Tư thế Thân người', subtitle: 'Lướt nước phẳng', desc: 'Giữ thân người thẳng, nằm ngang, song song với mặt nước. Tránh võng lưng hoặc gập hông quá mức để không làm tăng lực cản của nước.', icon: '🧍' },
    legs: { title: 'Động tác Chân', subtitle: 'Đạp chân ếch mạnh mẽ', desc: 'Co chân nhẹ nhàng bằng cách kéo gót về phía mông, bẻ cổ chân ra ngoài góc 90 độ (úp mu bàn chân). Đạp mạnh mẽ vòng cung rộng sang hai bên rồi khép chặt hai chân lại để lướt nước.', icon: '🦵' }
  },
  'hoc-boi-sai': {
    head: { title: 'Tư thế Đầu & Thở', subtitle: 'Xoay nghiêng thở tự nhiên', desc: 'Đầu luôn úp dưới nước, mắt nhìn thẳng xuống đáy bể hoặc chếch nhẹ về trước. Khi thở, xoay nghiêng đầu sang một bên vừa đủ để 1 mắt nằm dưới nước, 1 mắt trên nước để hớp hơi nhanh.', icon: '🗣️' },
    arms: { title: 'Động tác Tay', subtitle: 'Quạt nước luân phiên', desc: 'Tay quạt nước theo chu kỳ liên tục: Tỳ nước bằng lòng bàn tay, kéo nước chéo xuống dưới bụng, đẩy nước mạnh ra sau đùi. Vung tay trên không với cùi chỏ cao, thả lỏng cơ vai.', icon: '👐' },
    core: { title: 'Tư thế Thân người', subtitle: 'Trục thẳng xoay hông', desc: 'Thân người giữ trên một đường thẳng. Khi quạt tay, hông và vai tự động xoay nhẹ góc 30-45 độ sang hai bên theo nhịp quạt tay giúp kéo dài sải tay và giảm cản.', icon: '🧍' },
    legs: { title: 'Động tác Chân', subtitle: 'Đập chân sải liên tục', desc: 'Đập chân luân phiên từ khớp hông (không gập đầu gối quá mức), cổ chân thả lỏng hoàn toàn để mu bàn chân vẩy nước như đuôi cá. Biên độ đập chân lý tưởng là 30-40cm.', icon: '🦵' }
  },
  'hoc-boi-ngua': {
    head: { title: 'Tư thế Đầu & Thở', subtitle: 'Ngửa mặt tự nhiên', desc: 'Mặt hướng thẳng lên trần hoặc bầu trời, hai tai ngập hoàn toàn dưới mặt nước. Giữ đầu ổn định không nghiêng lắc, cằm hơi hướng về phía ngực để giữ phần thân trên nổi.', icon: '🗣️' },
    arms: { title: 'Động tác Tay', subtitle: 'Quạt tay chữ S luân phiên', desc: 'Hai tay vung luân phiên tạo vòng tròn 360 độ. Ngón cái rời nước trước, ngón út vào nước trước. Dưới nước, tay quạt cong hình chữ S để đẩy nước hiệu quả ra sau.', icon: '👐' },
    core: { title: 'Tư thế Thân người', subtitle: 'Ưỡn ngực nổi hông', desc: 'Thân người nằm ngửa phẳng trên mặt nước, hông đẩy cao lên sát mặt nước để tránh bị chìm mông. Tránh gập bụng tạo tư thế ngồi dưới nước.', icon: '🧍' },
    legs: { title: 'Động tác Chân', subtitle: 'Đập chân ngửa luân phiên', desc: 'Đập chân từ hông luân phiên ngược từ dưới lên trên. Cổ chân thả lỏng, dùng mu bàn chân để đẩy nước lên sát mặt nước tạo bọt trắng mịn.', icon: '🦵' }
  },
  'hoc-boi-buom': {
    head: { title: 'Tư thế Đầu & Thở', subtitle: 'Nhô đầu lấy hơi sớm', desc: 'Đầu nhô lên thở sớm ngay khi tay bắt đầu pha đẩy nước ra sau đùi. Tránh ngẩng đầu quá cao làm chìm hông. Khi tay vung qua vai vào nước, đầu phải úp xuống trước tay.', icon: '🗣️' },
    arms: { title: 'Động tác Tay', subtitle: 'Quạt tay hình lỗ khóa', desc: 'Cả hai tay hoạt động đồng thời. Pha quạt nước dưới bụng tạo đường cong giống chiếc lỗ khóa (kéo sát vào ngực rồi đẩy mạnh ra sau). Vung tay ngang thẳng trên mặt nước.', icon: '👐' },
    core: { title: 'Tư thế Thân người', subtitle: 'Uốn sóng cơ thể liên tục', desc: 'Chuyển động uốn sóng nhịp nhàng (Dolphin Kick) xuất phát từ ngực, truyền xuống hông rồi ra chân. Hông nhô lên hạ xuống liên tục tạo lực truyền động học.', icon: '🧍' },
    legs: { title: 'Động tác Chân', subtitle: 'Đập chân bướm đôi', desc: 'Hai chân khép sát đập đồng thời. Một chu kỳ bơi bướm có 2 nhịp đập chân: Nhịp 1 đập khi tay vào nước để nâng hông nổi, nhịp 2 đập khi tay đẩy nước ra sau để tạo lực tiến.', icon: '🦵' }
  },
  'ky-nang-dung-nuoc': {
    head: { title: 'Tư thế Đầu & Thở', subtitle: 'Thẳng đứng & Thở đều', desc: 'Giữ đầu thẳng đứng ổn định trên mặt nước. Hít thở sâu bằng miệng, thở ra bằng mũi một cách bình tĩnh, tránh hoảng loạn để phổi luôn chứa không khí giúp cơ thể tự nổi.', icon: '🗣️' },
    arms: { title: 'Động tác Tay', subtitle: 'Quạt nước tạo lực nâng', desc: 'Hai tay dang rộng sang hai bên dưới mặt nước, úp lòng bàn tay vẽ hình số 8 nằm ngang liên tục để tạo lực nâng (sculling) hỗ trợ cơ thể nổi ổn định.', icon: '👐' },
    core: { title: 'Tư thế Thân người', subtitle: 'Thẳng đứng thả lỏng', desc: 'Thân người giữ tư thế đứng hoặc hơi ngả nhẹ ra sau trong nước. Thả lỏng toàn bộ các nhóm cơ không tham gia vận động để tiết kiệm tối đa năng lượng sinh tồn.', icon: '🧍' },
    legs: { title: 'Động tác Chân', subtitle: 'Đạp chân ếch luân phiên', desc: 'Thực hiện đạp chân ếch luân phiên từng chân một (chân động cơ/eggbeater kick) hoặc đạp chân ếch đồng thời hướng xuống dưới đáy bể để tạo lực đẩy liên tục hướng lên.', icon: '🦵' }
  }
};

const currentAnatomy = anatomyData[technique.slug] || anatomyData['hoc-boi-sai'];

// Cấu hình tọa độ điểm hotspot tương ứng với từng hình ảnh giải phẫu học kiểu bơi (tính chính xác theo tỷ lệ % từ viewBox 600x300 của SVG)
const hotspotCoords = (() => {
  switch (technique.slug) {
    case 'hoc-boi-ech':
      return {
        head: { top: '33.3%', left: '69.2%' },
        arms: { top: '56.7%', left: '66.7%' },
        core: { top: '50%', left: '55.4%' },
        legs: { top: '65%', left: '50.8%' }
      };
    case 'hoc-boi-sai':
      return {
        head: { top: '40%', left: '68.3%' },
        arms: { top: '28.3%', left: '66.7%' },
        core: { top: '45.8%', left: '54.2%' },
        legs: { top: '55%', left: '28.7%' }
      };
    case 'hoc-boi-ngua':
      return {
        head: { top: '44%', left: '68.3%' },
        arms: { top: '25%', left: '56.7%' },
        core: { top: '50%', left: '54.2%' },
        legs: { top: '47.3%', left: '28.7%' }
      };
    case 'hoc-boi-buom':
      return {
        head: { top: '43.3%', left: '68.3%' },
        arms: { top: '30%', left: '69.2%' },
        core: { top: '49.2%', left: '54.2%' },
        legs: { top: '51.7%', left: '28.7%' }
      };
    case 'ky-nang-dung-nuoc':
      return {
        head: { top: '26.7%', left: '50%' },
        arms: { top: '48.3%', left: '56.7%' },
        core: { top: '54.2%', left: '50%' },
        legs: { top: '86.7%', left: '55.8%' }
      };
    default:
      return {
        head: { top: '40%', left: '80%' },
        arms: { top: '62%', left: '63%' },
        core: { top: '46%', left: '45%' },
        legs: { top: '38%', left: '20%' }
      };
  }
})();

// Cấu hình tone màu động dựa trên slug
const themeStyles = (() => {
  switch (technique.slug) {
    case 'hoc-boi-ech':
      return `
        --theme-primary: #009688;
        --theme-secondary: #00bcd4;
        --theme-dark: #004d40;
        --theme-glow: rgba(0, 150, 136, 0.35);
        --theme-accent: #ff6b6b;
      `;
    case 'hoc-boi-sai':
      return `
        --theme-primary: #0a4d8c;
        --theme-secondary: #00bcd4;
        --theme-dark: #052e56;
        --theme-glow: rgba(0, 188, 212, 0.35);
        --theme-accent: #ff6b6b;
      `;
    case 'hoc-boi-ngua':
      return `
        --theme-primary: #0288d1;
        --theme-secondary: #3f51b5;
        --theme-dark: #01579b;
        --theme-glow: rgba(2, 136, 209, 0.35);
        --theme-accent: #ff6b6b;
      `;
    case 'hoc-boi-buom':
      return `
        --theme-primary: #6a1b9a;
        --theme-secondary: #ff6e40;
        --theme-dark: #4a148c;
        --theme-glow: rgba(255, 110, 64, 0.35);
        --theme-accent: #ffd54f;
      `;
    case 'ky-nang-dung-nuoc':
      return `
        --theme-primary: #f57c00;
        --theme-secondary: #0077b6;
        --theme-dark: #e65100;
        --theme-glow: rgba(245, 124, 0, 0.35);
        --theme-accent: #ffeb3b;
      `;
    default:
      return `
        --theme-primary: #0a4d8c;
        --theme-secondary: #00bcd4;
        --theme-dark: #052e56;
        --theme-glow: rgba(0, 188, 212, 0.35);
        --theme-accent: #ff6b6b;
      `;
  }
})();
---

<PageLayout
  title={metadata.title}
  description={metadata.description}
  canonical={metadata.canonical}
  image={metadata.image}
  type="article"
  breadcrumbs={metadata.breadcrumbs}
  schema={metadata.articleSchema}
>
  {metadata.faqSchema && (
    <Fragment slot="head">
      <script type="application/ld+json" set:html={JSON.stringify(metadata.faqSchema)} />
    </Fragment>
  )}
  {metadata.howToSchema && (
    <Fragment slot="head">
      <script type="application/ld+json" set:html={JSON.stringify(metadata.howToSchema)} />
    </Fragment>
  )}

  <div class="technique-landing" style={themeStyles}>
    <!-- Reading Progress Line -->
    <div class="tl-reading-progress" id="reading-progress"></div>

    <!-- Hidden element for passing anatomy data to script -->
    <script type="application/json" id="anatomy-data-script" set:html={JSON.stringify(anatomyData[technique.slug] || anatomyData['hoc-boi-sai'])} />

    <!-- Hero Section -->
    <section class="tl-hero">
      <div class="tl-hero__refractions">
        <div class="tl-light-ray"></div>
        <div class="tl-light-ray"></div>
        <div class="tl-light-ray"></div>
        <div class="tl-light-ray"></div>
      </div>
      
      <div class="tl-hero__container">
        <div class="tl-hero__main-row">
          <div class="tl-hero__text-side">
            <span class="tl-hero__badge">{technique.badge}</span>
            <h1 class="tl-hero__title">
              {technique.name}: Hướng Dẫn Kỹ Thuật <span class="highlight">Chi Tiết Nhất</span>
            </h1>
            <p class="tl-hero__description">
              {technique.description}
            </p>
            
            <div class="tl-hero__ctas">
              <a href="#dang-ky" class="tl-btn tl-btn--accent tl-btn--pulse">📞 Học Thử Miễn Phí</a>
              <a href={`#${toc[0]?.id || 'gioi-thieu'}`} class="tl-btn tl-btn--outline">📖 Xem Kỹ Thuật</a>
            </div>
          </div>

          <div class="tl-hero__video-side">
            <div class="tl-hero__video">
              <YouTubeVideo
                videoId={technique.videoId}
                poster={technique.videoPoster}
                alt={technique.videoAlt}
                width={560}
                height={315}
              />
            </div>
          </div>
        </div>

        <!-- Quick Specs Row (Sports Science Dashboard style V2 - Circular Gauges) -->
        <div class="tl-hero__stats">
          <div class="tl-gauge-card tl-gauge-card--difficulty">
            <div class="tl-gauge-wrapper">
              <svg class="tl-gauge-svg" viewBox="0 0 80 80">
                <circle class="tl-gauge-bg" cx="40" cy="40" r="34" fill="none" stroke-width="6"></circle>
                <circle class="tl-gauge-fg" cx="40" cy="40" r="34" fill="none" stroke-width="6" stroke-linecap="round" stroke-dasharray="213.6" stroke-dashoffset={diffOffset} stroke="var(--theme-secondary)"></circle>
              </svg>
              <div class="tl-gauge-text">
                <span class="tl-gauge-num">{diffIndex + 1}</span><span class="tl-gauge-total">/4</span>
              </div>
            </div>
            <div class="tl-gauge-info">
              <span class="tl-gauge-label">Độ khó</span>
              <span class="tl-gauge-val">{technique.difficulty}</span>
            </div>
          </div>
          
          <div class="tl-gauge-card tl-gauge-card--speed">
            <div class="tl-gauge-wrapper">
              <svg class="tl-gauge-svg" viewBox="0 0 80 80">
                <circle class="tl-gauge-bg" cx="40" cy="40" r="34" fill="none" stroke-width="6"></circle>
                <circle class="tl-gauge-fg" cx="40" cy="40" r="34" fill="none" stroke-width="6" stroke-linecap="round" stroke-dasharray="213.6" stroke-dashoffset={speedOffset} stroke="var(--theme-secondary)"></circle>
              </svg>
              <div class="tl-gauge-text">
                <span class="tl-gauge-icon">⚡</span>
              </div>
            </div>
            <div class="tl-gauge-info">
              <span class="tl-gauge-label">Tốc độ</span>
              <span class="tl-gauge-val">{technique.speed}</span>
            </div>
          </div>
          
          <div class="tl-gauge-card tl-gauge-card--calories">
            <div class="tl-gauge-wrapper">
              <svg class="tl-gauge-svg" viewBox="0 0 80 80">
                <circle class="tl-gauge-bg" cx="40" cy="40" r="34" fill="none" stroke-width="6"></circle>
                <circle class="tl-gauge-fg tl-gauge-fg--energy" cx="40" cy="40" r="34" fill="none" stroke-width="6" stroke-linecap="round" stroke-dasharray="213.6" stroke-dashoffset={calOffset} stroke="#FF8E53"></circle>
              </svg>
              <div class="tl-gauge-text">
                <span class="tl-gauge-icon">🔥</span>
              </div>
            </div>
            <div class="tl-gauge-info">
              <span class="tl-gauge-label">Calo tiêu thụ</span>
              <span class="tl-gauge-val">{technique.calories}</span>
            </div>
          </div>
          
          <div class="tl-gauge-card tl-gauge-card--muscles">
            <div class="tl-muscles-hub">
              <span class="tl-muscles-hub__icon">💪</span>
              <span class="tl-gauge-label">Cơ tác động chính</span>
            </div>
            <div class="tl-muscles-tags">
              {musclesList.map(muscle => (
                <span class="tl-muscle-tag">{muscle}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Table of Contents sticky bar / vertical navigation -->
    <div class="tl-toc-wrapper">
      <nav class="tl-toc-nav" aria-label="Mục lục nhanh">
