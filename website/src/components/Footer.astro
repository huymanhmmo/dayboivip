          <a href="/khoa-hoc-boi/doanh-nghiep/" class="footer-link">Doanh nghiệp & Vinhomes</a>
          <a href="/khoa-hoc-boi/tre-em/" class="footer-link">Học bơi trẻ em</a>
          <a href="/khoa-hoc-boi/nguoi-lon/" class="footer-link">Học bơi người lớn</a>
          <a href="/khoa-hoc-boi/nguoi-cao-tuoi/" class="footer-link">Học bơi người cao tuổi</a>
          <a href="/khoa-hoc-boi/nguoi-so-nuoc/" class="footer-link">Học bơi người sợ nước</a>
        </nav>
      </div>

      <!-- Techniques Column -->
      <div class="footer-col-techniques">
        <h3 class="footer-title">Kỹ Thuật Bơi</h3>
        <nav class="footer-links" aria-label="Kỹ thuật bơi">
