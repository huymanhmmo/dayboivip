---
export interface Props {
  benefits: Array<{ icon: string; title: string; description: string }>;
}

const { benefits } = Astro.props;
---

<section class="cl-section cl-section--alt">
  <div class="cl-section__container">
    <div class="cl-section-title">
      <span class="cl-section-title__badge">
        Lợi Ích Khóa Học
      </span>
      <h2 class="cl-section-title__heading cl-section-title__heading--gradient">
        Cam Kết Giá Trị Nhận Được
      </h2>
      <p class="cl-section-title__sub">
        Chúng tôi tập trung vào chất lượng giảng dạy và trải nghiệm an toàn của học viên để mang lại giá trị bền vững.
      </p>
      <span class="cl-section-title__decoration"></span>
    </div>

    <div class="cl-usp__grid">
      {benefits.map((benefit, index) => (
        <div class={`cl-card cl-usp__card cl-animate cl-animate--delay-${index + 1}`}>
          <div class="cl-usp__icon-box">
            <span class="cl-usp__icon">{benefit.icon}</span>
          </div>
          <h3 class="cl-usp__title">{benefit.title}</h3>
          <p class="cl-usp__desc">{benefit.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .cl-usp__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-top: 40px;
  }

  .cl-usp__card {
    padding: 32px;
  }

  .cl-usp__icon-box {
    width: 60px;
    height: 60px;
    border-radius: var(--cl-radius-sm);
    background: linear-gradient(135deg, var(--cl-primary), var(--cl-cyan));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    color: #fff;
    margin-bottom: 20px;
    box-shadow: 0 8px 20px rgba(0, 188, 212, 0.2);
  }

  .cl-usp__title {
    font-family: var(--cl-font);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--cl-dark);
    margin: 0 0 12px;
  }

  .cl-usp__desc {
    font-size: 0.95rem;
    color: var(--cl-text-light);
    line-height: 1.65;
    margin: 0;
  }

  @media (min-width: 768px) {
    .cl-usp__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
