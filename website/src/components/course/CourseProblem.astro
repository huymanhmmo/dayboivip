---
export interface Props {
  problems: {
    title: string;
    subtitle: string;
    items: Array<{ icon: string; title: string; description: string }>;
  };
}

const { problems } = Astro.props;
---

<section class="cl-section">
  <div class="cl-section__container">
    <div class="cl-section-title">
      <span class="cl-section-title__badge">
        Rào Cản & Thách Thức
      </span>
      <h2 class="cl-section-title__heading">
        {problems.title}
      </h2>
      <p class="cl-section-title__sub">
        {problems.subtitle}
      </p>
      <span class="cl-section-title__decoration"></span>
    </div>

    <div class="cl-problem__grid">
      {problems.items.map((item, index) => (
        <div class={`cl-problem__card cl-animate cl-animate--delay-${index + 1}`}>
          <div class="cl-problem__icon-box">
            <span class="cl-problem__icon">{item.icon}</span>
          </div>
          <div class="cl-problem__text">
            <h3 class="cl-problem__item-title">{item.title}</h3>
            <p class="cl-problem__item-desc">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .cl-problem__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-top: 40px;
  }

  .cl-problem__card {
    background: #FFF5F5; /* Very light warm coral red */
    border-radius: var(--cl-radius);
    padding: 28px;
    border: 1px dashed rgba(255, 107, 107, 0.3);
    display: flex;
    gap: 20px;
    transition: all 0.3s var(--cl-ease);
  }

  .cl-problem__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 24px rgba(255, 107, 107, 0.08);
    border-color: rgba(255, 107, 107, 0.5);
  }

  .cl-problem__icon-box {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: #FFE3E3;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 1.5rem;
  }

  .cl-problem__text {
    flex: 1;
  }

  .cl-problem__item-title {
    font-family: var(--cl-font);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--cl-dark);
    margin: 0 0 8px;
  }

  .cl-problem__item-desc {
    font-size: 0.95rem;
    color: var(--cl-text-light);
    line-height: 1.6;
    margin: 0;
  }

  @media (min-width: 768px) {
    .cl-problem__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
