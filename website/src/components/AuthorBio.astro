---
export interface Props {
  name?: string;
  role?: string;
  avatar?: string;
  bio?: string;
}

const {
  name = 'Thầy Nguyễn Huy Mạnh',
  role = 'Giám Đốc & HLV Trưởng Swim For Life Việt Nam',
  avatar = '/images/team/thay-nguyen-huy-manh.jpg',
  bio = 'Thầy Nguyễn Huy Mạnh tốt nghiệp khoa Giáo dục Thể chất trường Đại học Sư phạm Hà Nội. Với hơn 10 năm kinh nghiệm huấn luyện bơi lội từ cơ bản đến nâng cao, thầy đã phổ cập bơi thành công cho hơn 10.000 học sinh, đặc biệt nổi tiếng với các phương pháp sư phạm sư phạm dễ hiểu, tâm lý vững vàng hỗ trợ học viên nhát nước, sợ nước vượt qua nỗi sợ bơi lội.'
} = Astro.props;
---

<div class="author-bio-footer">
  <div class="author-bio-footer-avatar">
    <img src={avatar} alt={name} width="80" height="80" style="border-radius: 50%; object-fit: cover;" loading="lazy" />
  </div>
  <div class="author-bio-footer-content">
    <h3 class="author-bio-footer-title">{name}</h3>
    <span class="author-bio-footer-role">{role}</span>
    <p class="author-bio-footer-text">{bio}</p>
  </div>
</div>
