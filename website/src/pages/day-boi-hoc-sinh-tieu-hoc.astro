---
import BlogLayout from '../layouts/BlogLayout.astro';
import { blogPosts } from '../data/blogPosts.js';

const post = blogPosts.find((p) => p.slug === 'day-boi-hoc-sinh-tieu-hoc');
if (!post) {
  throw new Error('Post not found in blogPosts.js');
}

const breadcrumbs = [
  { label: 'Trang chủ', href: '/' },
  { label: 'Tin tức', href: '/tin-tuc/' },
  { label: post.category, href: `/${post.categorySlug}/` },
  { label: post.title },
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.excerpt,
  "image": `https://dayboi.vip${post.image}`,
  "author": {
    "@type": "Person",
    "name": "Nguyễn Huy Mạnh",
    "jobTitle": "Giám đốc đào tạo",
    "url": "https://dayboi.vip/#founder"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Swim For Life Việt Nam",
    "logo": {
      "@type": "ImageObject",
      "url": "https://dayboi.vip/images/logo/swim-for-life-logo.png"
    }
  },
  "datePublished": "2026-05-25",
  "dateModified": "2026-05-25",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://dayboi.vip/${post.slug}/`
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Học sinh tiểu học mấy tuổi học bơi là thích hợp nhất?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Độ tuổi thích hợp nhất để bắt đầu học bơi bài bản ở bậc tiểu học là từ 6 đến 8 tuổi. Lúc này, trẻ đã phát triển tốt về hệ cơ xương khớp, có khả năng tập trung tiếp thu bài giảng sư phạm dài 45-60 phút và hiểu rõ các hiệu lệnh đảm bảo an toàn của giáo viên dưới nước."
      }
    },
    {
      "@type": "Question",
      "name": "Học bơi cho bé tiểu học mất bao nhiêu buổi thì biết bơi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Thời gian trung bình để học sinh tiểu học biết bơi cơ bản (bơi ếch học sinh từ 25-50m không cần phao) là khoảng 10 đến 12 buổi học nghiêm túc. Với những bé nhút nhát hoặc sợ nước nặng, thời gian làm quen nước có thể kéo dài thêm từ 2 đến 3 buổi dưới sự hỗ trợ chuyên biệt của HLV."
      }
    },
    {
      "@type": "Question",
      "name": "Trường học có tổ chức học bơi, tại sao vẫn nên cho bé học tại trung tâm chuyên nghiệp?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Học bơi tại trường thường theo lớp đông (20-30 học sinh/thầy), giáo viên khó quan sát và sửa lỗi kỹ thuật chi tiết cho từng bé, dễ dẫn đến sai tư thế hoặc sợ nước vì thiếu sự kèm cặp. Trong khi đó, tại trung tâm chuyên nghiệp như Swim For Life, mô hình dạy kèm nhóm nhỏ (tối đa 3-4 học sinh) hoặc kèm riêng 1:1 đảm bảo an toàn tuyệt đối, sửa lỗi tỉ mỉ và giúp bé nhanh biết bơi hơn."
      }
    },
    {
      "@type": "Question",
      "name": "Bé bị sợ nước nặng thì trung tâm có phương pháp dạy bơi đặc biệt gì không?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Với bé sợ nước, HLV sư phạm của Swim For Life áp dụng phương pháp 'tiếp cận chậm qua trò chơi'. Bé được ngồi chơi trên thành bể, thả chân xuống nước, thổi bong bóng nước, chơi nhặt bóng cạn mà không ép buộc ngâm mình ngay. Khi bé đã tin tưởng HLV và vượt qua rào cản tâm lý, các kỹ năng sinh tồn sẽ được đưa vào bài học một cách tự nhiên."
      }
    },
    {
      "@type": "Question",
      "name": "Chứng chỉ bơi tiểu học do cơ quan nào cấp và có giá trị như thế nào?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Chứng chỉ bơi cho học sinh tiểu học được cấp bởi Sở Giáo dục và Đào tạo phối hợp với Trung tâm Thể dục Thể thao quận/huyện hoặc các cơ sở liên kết được cấp phép. Chứng chỉ này xác nhận bé đã hoàn thành phổ cập bơi, đạt chuẩn cự ly tối thiểu 25m và biết kỹ năng tự cứu, là điều kiện cộng điểm hoặc ưu tiên xét tuyển ở một số trường THCS chất lượng cao."
      }
    },
    {
      "@type": "Question",
      "name": "Có cần chuẩn bị phao bơi riêng cho học sinh khi đi học không?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tại Swim For Life, toàn bộ phao bơi (phao lưng, phao tim) và giáo trình học tập đều được trung tâm trang bị đầy đủ tại bể bơi. Phụ huynh chỉ cần chuẩn bị cho bé đồ bơi co giãn tốt, kính bơi trẻ em chất lượng cao ngăn nước vào mắt, mũ bơi giữ tóc gọn gàng và khăn lau người lớn sau khi lên bờ."
      }
    }
  ]
};

const tocItems = [
  { id: 'phan-1-cap-thiet', text: '1. Tại sao việc dạy bơi cho học sinh tiểu học lại cấp thiết?' },
  { id: 'phan-2-lo-trinh', text: '2. Lộ trình chương trình dạy bơi tiểu học chuẩn sinh tồn' },
  { id: 'phan-3-tam-ly', text: '3. Tâm lý học sinh tiểu học khi học bơi và cách HLV sư phạm tiếp cận' },
  { id: 'phan-4-so-sanh', text: '4. So sánh lớp bơi tiểu học tại trường vs tại trung tâm chuyên nghiệp' },
  { id: 'phan-5-quy-trinh', text: '5. Quy trình dạy học bơi cho bé tiểu học từ sợ nước đến biết bơi' },
  { id: 'phan-6-ky-nang', text: '6. Các kỹ năng sinh tồn bắt buộc học sinh tiểu học phải biết' },
  { id: 'phan-7-trang-bi', text: '7. Trang bị cần thiết cho học sinh tiểu học đi học bơi' },
  { id: 'phan-8-hoc-phi', text: '8. Học phí lớp bơi tiểu học và ưu đãi cho nhóm học sinh' },
  { id: 'phan-9-chung-chi', text: '9. Chứng chỉ bơi cho học sinh tiểu học: Điều kiện và quy trình thi' },
  { id: 'phan-10-vai-tro', text: '10. Vai trò phối hợp của phụ huynh trong quá trình dạy bơi' },
  { id: 'phan-11-case-study', text: '11. Case study thực tế tại Swim For Life' },
  { id: 'phan-12-faq', text: '12. Câu hỏi thường gặp về lớp bơi tiểu học (FAQ)' }
