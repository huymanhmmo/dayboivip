  { id: 'sai-lam-lam-dung-phao', text: '9. Sai lầm khi lạm dụng phao bơi trong giảng dạy' },
  { id: 'dia-chi-mua-uy-tin', text: '10. Gợi ý địa chỉ mua dụng cụ bơi uy tín giá tốt' },
