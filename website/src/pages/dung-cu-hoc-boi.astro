if (!post) {
  throw new Error('Post not found in blogPosts.js');
}

const breadcrumbs = [
  { label: 'Trang chủ', href: '/' },
  { label: 'Tin tức', href: '/tin-tuc/' },
  { label: post.category, href: `/${post.categorySlug}/` },
  { label: post.title },
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.excerpt,
  "image": `https://dayboi.vip${post.image}`,
  "author": {
    "@type": "Person",
    "name": "Nguyễn Huy Mạnh",
    "jobTitle": "Giám đốc đào tạo",
    "url": "https://dayboi.vip/#founder"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Swim For Life Việt Nam",
    "logo": {
      "@type": "ImageObject",
      "url": "https://dayboi.vip/images/logo/swim-for-life-logo.png"
    }
  },
  "datePublished": "2026-05-25",
  "dateModified": "2026-05-25",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://dayboi.vip/${post.slug}/`
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Học sinh mới bắt đầu học bơi cần chuẩn bị những dụng cụ tối thiểu nào?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Học sinh mới bắt đầu học bơi cần chuẩn bị tối thiểu 4 dụng cụ cơ bản: đồ bơi co giãn tốt, kính bơi chống mờ bảo vệ mắt, mũ bơi giữ gọn tóc và phao lưng hỗ trợ lực nổi ngang cho cơ thể dưới nước."
      }
    },
    {
      "@type": "Question",
      "name": "Có nên mua phao lưng học bơi cho trẻ mầm non không?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Có, phao lưng học bơi là cực kỳ cần thiết cho trẻ mầm non. Tuy nhiên, đối với trẻ từ 3-5 tuổi, bố mẹ nên kết hợp phao lưng với phao nâng cơ tay (hoặc phao puddle jumper) dưới sự giám sát liên tục của người lớn để đảm bảo an toàn tuyệt đối."
      }
    },
    {
      "@type": "Question",
      "name": "Làm sao để phân biệt kính bơi học sinh chính hãng và hàng giả?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Kính bơi chính hãng có đệm silicone mềm dẻo không mùi, thấu kính polycarbonate trong suốt không gây méo hình, hộp đựng in mã vạch nét chữ rõ ràng và giá không dưới 150.000 VNĐ. Kính bơi giả thường có mùi nhựa tái chế nồng, đệm cao su cứng gây đau mắt và thấu kính dễ trầy xước."
      }
    },
    {
      "@type": "Question",
      "name": "Tại sao kính bơi hay bị mờ sau một thời gian sử dụng và cách khắc phục?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Kính bơi bị mờ là do lớp phủ chống sương mù (anti-fog) nguyên bản bị bong tróc do học viên vô tình dùng tay lau hoặc rửa bằng xà phòng. Để khắc phục, bạn nên dùng nước rửa kính chống mờ chuyên dụng (anti-fog spray) xịt nhẹ trước khi bơi hoặc rửa sạch bằng nước mát sau khi bơi."
      }
    },
    {
      "@type": "Question",
      "name": "Trẻ em có nên dùng nút bịt tai khi bơi không?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nên dùng nếu trẻ dễ bị viêm tai giữa hoặc nhạy cảm với nước bể bơi. Chọn nút bịt tai bằng silicone mềm y tế, có kích thước nhỏ phù hợp ống tai của học sinh để cản nước hiệu quả mà không gây đau tức."
      }
    },
    {
      "@type": "Question",
      "name": "Lớp học bơi tại Swim For Life có cung cấp sẵn phao bơi và dụng cụ tập luyện không?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tại Swim For Life, tất cả các dụng cụ hỗ trợ tập luyện chuyên sâu như phao lưng, phao tim, phao nâng cơ, ống thở và phao kéo chân đều được trung tâm trang bị đầy đủ tại các buổi học. Phụ huynh chỉ cần chuẩn bị đồ bơi, kính bơi và mũ bơi cá nhân cho bé."
      }
    }
  ]
};

const tocItems = [
  { id: 'vai-tro-dung-cu', text: '1. Tại sao dụng cụ học bơi quyết định đến an toàn?' },
