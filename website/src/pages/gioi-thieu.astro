---
import PageLayout from '../layouts/PageLayout.astro';
import YouTubeVideo from '../components/YouTubeVideo.astro';

const title = 'Giới Thiệu Swim For Life Việt Nam: Trung Tâm Dạy Bơi Uy Tín Hàng Đầu Việt Nam';
const description = 'Tìm hiểu về Trung tâm dạy bơi Swim For Life Việt Nam - Lịch sử hình thành, sứ mệnh phổ cập bơi lội, đội ngũ HLV chuyên nghiệp và cam kết chất lượng.';

const breadcrumbs = [
  { label: 'Trang chủ', href: '/' },
  { label: 'Giới thiệu' }
];

const faqData = [
  {
    question: 'Swim For Life hoạt động từ năm nào?',
    answer: 'Swim For Life được thành lập và hoạt động từ hơn 10 năm trước, bắt đầu từ một nhóm HLV đam mê bơi lội với sứ mệnh phổ cập kỹ năng bơi lội cho người Việt Nam, đặc biệt là trẻ em. Trải qua hơn một thập kỷ phát triển, chúng tôi đã trở thành một trong những trung tâm dạy bơi uy tín hàng đầu Việt Nam.'
  },
  {
    question: 'Swim For Life có bao nhiêu HLV?',
    answer: 'Swim For Life hiện có đội ngũ hàng chục HLV chuyên nghiệp hoạt động tại Hà Nội và TP.HCM. Tất cả HLV đều tốt nghiệp từ các trường ĐH Sư phạm, ĐH Thể dục Thể thao, có chứng chỉ HLV bơi lội, chứng chỉ sơ cứu cấp cứu và được đào tạo kỹ năng tâm lý sư phạm.'
  },
  {
    question: 'Swim For Life có phải là đối tác chính thức của Vinhomes không?',
    answer: 'Đúng vậy! Swim For Life là đối tác chính thức của Vinhomes trong chương trình dạy bơi miễn phí cho cư dân. Chúng tôi hiện có mặt tại nhiều khu đô thị Vinhomes như Times City, Ocean Park, Smart City, Grand Park và đã tổ chức thành công Giải bơi Kình ngư Ocean City.'
  },
  {
    question: 'Triết lý giảng dạy của Swim For Life là gì?',
    answer: 'Swim For Life theo đuổi triết lý "Lấy học viên làm trung tâm". Chúng tôi tin rằng mỗi người đều có khả năng học bơi, điều quan trọng là phương pháp và sự kiên nhẫn. HLV của chúng tôi không chỉ dạy kỹ thuật mà còn giúp học viên vượt qua nỗi sợ nước, xây dựng sự tự tin và yêu thích hoạt động dưới nước.'
  },
  {
    question: 'Swim For Life có cấp chứng chỉ hoàn thành khóa học không?',
    answer: 'Có! Sau khi hoàn thành khóa học và đạt chuẩn kỹ năng, học viên sẽ được cấp Giấy chứng nhận hoàn thành khóa học bơi, xác nhận kỹ năng bơi đạt chuẩn an toàn. Chứng chỉ này có giá trị trong các hoạt động liên quan đến bơi lội và thể thao dưới nước.'
  },
  {
    question: 'Làm thế nào để liên hệ với Swim For Life?',
    answer: 'Bạn có thể liên hệ với Swim For Life qua Hotline: 0979.121.097, email dayboivip@gmail.com, hoặc đăng ký trực tuyến tại trang web. Chúng tôi hoạt động từ 6:00 - 21:00 hàng ngày, kể cả thứ 7 và Chủ nhật.'
  }
];

const aboutSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": title,
  "description": description,
  "url": "https://dayboi.vip/gioi-thieu/",
  "mainEntity": {
    "@type": "LocalBusiness",
    "@id": "https://dayboi.vip/#organization",
    "name": "Trung tâm dạy bơi Swim For Life Việt Nam",
    "founder": {
      "@type": "Person",
      "name": "Nguyễn Huy Mạnh",
      "jobTitle": "Giám đốc",
      "alumniOf": {
        "@type": "EducationalOrganization",
        "name": "Đại học Sư phạm Hà Nội"
      }
    }
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqData.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<PageLayout
  title={title}
  description={description}
  canonical="https://dayboi.vip/gioi-thieu/"
  breadcrumbs={breadcrumbs}
  schema={aboutSchema}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- ============ HERO SECTION — PREMIUM ============ -->
  <section class="about-hero">
    <div class="about-hero__bg">
      <div class="about-hero__orb about-hero__orb--1"></div>
      <div class="about-hero__orb about-hero__orb--2"></div>
      <div class="about-hero__orb about-hero__orb--3"></div>
      <div class="about-hero__particles" id="heroParticles"></div>
    </div>
    <div class="container about-hero__inner">
      <div class="about-hero__badge anim-fade-in">
        <span class="about-hero__badge-dot"></span>
        Hơn 10 Năm Đào Tạo Bơi Lội Chuyên Nghiệp
      </div>
      <h1 class="about-hero__title anim-fade-in anim-delay-1">
        Giới Thiệu <span class="about-hero__highlight">Swim For Life</span> Việt Nam
      </h1>
      <p class="about-hero__subtitle anim-fade-in anim-delay-2">
        Chúng tôi không chỉ dạy bơi — chúng tôi trang bị kỹ năng sinh tồn và niềm đam mê thể thao dưới nước cho hơn <strong>10.000 học viên</strong> trên khắp Việt Nam.
      </p>

      <!-- Animated Stats -->
      <div class="about-hero__stats anim-fade-in anim-delay-3">
        <div class="about-hero__stat">
          <span class="about-hero__stat-number" data-count="10000">0</span>
          <span class="about-hero__stat-suffix">+</span>
          <span class="about-hero__stat-label">Học viên</span>
        </div>
        <div class="about-hero__stat-divider"></div>
        <div class="about-hero__stat">
          <span class="about-hero__stat-number" data-count="10">0</span>
          <span class="about-hero__stat-suffix">năm+</span>
          <span class="about-hero__stat-label">Kinh nghiệm</span>
        </div>
        <div class="about-hero__stat-divider"></div>
        <div class="about-hero__stat">
          <span class="about-hero__stat-number" data-count="50">0</span>
          <span class="about-hero__stat-suffix">+</span>
          <span class="about-hero__stat-label">Bể bơi liên kết</span>
        </div>
        <div class="about-hero__stat-divider"></div>
        <div class="about-hero__stat">
          <span class="about-hero__stat-number" data-count="2">0</span>
          <span class="about-hero__stat-suffix">TP lớn</span>
          <span class="about-hero__stat-label">Hà Nội & TP.HCM</span>
        </div>
      </div>
    </div>
    <!-- Wave -->
    <div class="about-hero__wave">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
        <path d="M0,80 C360,120 720,40 1080,80 C1260,100 1380,60 1440,80 L1440,120 L0,120 Z" fill="var(--color-bg)"/>
        <path d="M0,90 C320,130 640,50 960,90 C1120,105 1300,70 1440,90 L1440,120 L0,120 Z" fill="var(--color-bg)" opacity="0.5"/>
      </svg>
    </div>
  </section>

  <!-- ============ MỤC LỤC + LỊCH SỬ ============ -->
  <section class="about-section">
    <div class="container">
      <!-- TOC -->
      <nav class="about-toc reveal">
        <div class="about-toc__header">
          <span class="about-toc__icon">📑</span>
          <h2 class="about-toc__title">Mục lục bài viết</h2>
        </div>
        <ol class="about-toc__list">
          <li><a href="#lich-su-hinh-thanh">Lịch sử hình thành Swim For Life</a></li>
          <li><a href="#su-menh-tam-nhin">Sứ mệnh & Tầm nhìn</a></li>
          <li><a href="#giam-doc">Giám đốc Nguyễn Huy Mạnh</a></li>
          <li><a href="#doi-ngu-hlv">Đội ngũ Huấn luyện viên</a></li>
          <li><a href="#thanh-tuu">Thành tựu nổi bật</a></li>
          <li><a href="#chung-chi-giay-phep">Chứng chỉ & Giấy phép</a></li>
          <li><a href="#cam-ket-chat-luong">Cam kết chất lượng</a></li>
          <li><a href="#faq-gioi-thieu">Câu hỏi thường gặp</a></li>
        </ol>
      </nav>

      <!-- HISTORY SECTION -->
      <div class="about-content" id="lich-su-hinh-thanh">
        <div class="about-section-header reveal">
          <span class="about-section-badge">🏛️ Lịch Sử</span>
          <h2 class="about-section-title">Lịch Sử Hình Thành Trung Tâm Dạy Bơi Swim For Life Việt Nam</h2>
        </div>

        <div class="about-history reveal">
          <div class="about-history__text">
            <p>
              <strong>Trung tâm dạy bơi Swim For Life Việt Nam</strong> ra đời từ niềm đam mê bơi lội cháy bỏng và trăn trở trước thực trạng 
              đuối nước ở trẻ em Việt Nam. Theo thống kê của Tổ chức Y tế Thế giới (WHO), Việt Nam là một trong những quốc gia có tỷ lệ 
              đuối nước ở trẻ em cao nhất khu vực Đông Nam Á, với hàng nghìn trường hợp đau lòng xảy ra mỗi năm. Từ thực trạng đáng báo 
              động đó, thầy <strong>Nguyễn Huy Mạnh</strong> - người sáng lập Swim For Life - đã quyết tâm xây dựng một trung tâm dạy bơi 
              chuyên nghiệp với sứ mệnh phổ cập kỹ năng bơi lội cho người Việt.
            </p>

            <p>
              Bắt đầu từ một nhóm nhỏ các huấn luyện viên (HLV) tâm huyết, Swim For Life dần mở rộng quy mô hoạt động, từ vài chục học viên 
              ban đầu đến hàng nghìn học viên mỗi năm. Trải qua hơn <strong>10 năm</strong> xây dựng và phát triển không ngừng, Swim For Life 
              đã khẳng định vị thế là một trong những trung tâm dạy bơi uy tín hàng đầu tại Việt Nam, hoạt động tại hai thành phố lớn nhất cả 
              nước: <a href="/lien-he/">Hà Nội và TP. Hồ Chí Minh</a>.
            </p>

            <p>
              Swim For Life trực thuộc <strong>Công ty Cổ phần Your Dreams</strong> (Mã số thuế: 0108879900), một doanh nghiệp được thành lập 
              hợp pháp theo pháp luật Việt Nam. Với nền tảng pháp lý vững chắc, đội ngũ quản lý chuyên nghiệp và phương pháp đào tạo bài bản, 
              Swim For Life đã từng bước vươn lên, trở thành thương hiệu dạy bơi được tin tưởng và lựa chọn bởi hàng nghìn gia đình trên khắp 
              cả nước.
            </p>
          </div>

          <!-- Company Structure Card -->
          <div class="about-company-card reveal">
            <div class="about-company-card__item">
              <img src="/images/logo/swim-for-life-logo.png" alt="Logo Swim For Life Việt Nam" loading="lazy" />
              <span>Trung Tâm Dạy Bơi<br/>Swim For Life</span>
            </div>
            <div class="about-company-card__arrow">
              <span>Trực thuộc</span>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="about-company-card__item">
              <img src="/images/logo/your-dreams-logo.png" alt="Logo Công ty Cổ phần Your Dreams" loading="lazy" />
              <span>Công Ty Cổ Phần<br/>Your Dreams</span>
            </div>
          </div>

          <div class="about-history__text reveal">
            <p>
              Một trong những dấu mốc quan trọng nhất trong hành trình phát triển của Swim For Life là trở thành <strong>đối tác chính thức 
              của Vinhomes</strong> - tập đoàn bất động sản hàng đầu Việt Nam. Sự hợp tác này không chỉ khẳng định uy tín của Swim For Life 
              mà còn mở ra cơ hội để hàng nghìn cư dân Vinhomes được tiếp cận với chương trình dạy bơi chất lượng cao, hoàn toàn miễn phí. 
              Từ Vinhomes Times City, Ocean Park đến Smart City, Swim For Life đã phủ sóng tại nhiều khu đô thị lớn, mang lại kỹ năng bơi lội 
              an toàn cho cộng đồng cư dân.
            </p>
          </div>

          <blockquote class="about-quote reveal">
            <div class="about-quote__mark">"</div>
            <p class="about-quote__text">
              Chúng tôi bắt đầu từ một ước mơ đơn giản: mỗi đứa trẻ Việt Nam đều biết bơi, đều có kỹ năng tự cứu mình dưới nước. 
              Và sau hơn 10 năm, ước mơ đó đang dần trở thành hiện thực.
            </p>
            <footer class="about-quote__author">
              <img src="/images/team/thay-nguyen-huy-manh.jpg" alt="Thầy Nguyễn Huy Mạnh" loading="lazy" />
              <div>
                <strong>Thầy Nguyễn Huy Mạnh</strong>
                <span>Giám đốc Swim For Life Việt Nam</span>
              </div>
            </footer>
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SỨ MỆNH & TẦM NHÌN ============ -->
  <section class="about-section about-section--alt" id="su-menh-tam-nhin">
    <div class="container">
      <div class="about-section-header reveal">
        <span class="about-section-badge">🎯 Sứ Mệnh</span>
        <h2 class="about-section-title">Sứ Mệnh & Tầm Nhìn Của Swim For Life</h2>
      </div>

      <div class="about-mission-grid reveal">
        <!-- Mission Card -->
        <div class="about-mission-card about-mission-card--mission">
          <div class="about-mission-card__icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width="2"/><path d="M24 14v10l7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="24" cy="24" r="4" fill="currentColor" opacity="0.3"/></svg>
          </div>
          <h3>Sứ mệnh</h3>
          <p>
            Sứ mệnh của Swim For Life là <strong>phổ cập kỹ năng bơi lội và phòng chống đuối nước</strong> cho mọi đối tượng, đặc biệt là 
            trẻ em Việt Nam. Chúng tôi tin rằng bơi lội không chỉ là một môn thể thao, mà là một <strong>kỹ năng sinh tồn thiết yếu</strong> 
            mà mỗi người cần được trang bị ngay từ nhỏ.
          </p>
          <ul class="about-mission-list">
            <li>
              <span class="about-mission-list__icon">🏊</span>
              <div><strong>Kỹ năng sinh tồn dưới nước:</strong> Biết bơi, biết đứng nước, biết tự cứu mình trong tình huống khẩn cấp.</div>
            </li>
            <li>
              <span class="about-mission-list__icon">💪</span>
              <div><strong>Rèn luyện sức khỏe:</strong> Phát triển cơ bắp, tăng cường tim mạch, cải thiện hệ hô hấp toàn diện.</div>
            </li>
            <li>
              <span class="about-mission-list__icon">⭐</span>
              <div><strong>Phát triển tự tin:</strong> Giúp <a href="/khoa-hoc-boi/tre-em/">trẻ em</a> vượt qua nỗi sợ, xây dựng bản lĩnh.</div>
            </li>
            <li>
              <span class="about-mission-list__icon">❤️</span>
              <div><strong>Thói quen lành mạnh:</strong> Tạo dựng lối sống vận động, nâng cao chất lượng cuộc sống.</div>
            </li>
          </ul>
        </div>

        <!-- Vision Card -->
        <div class="about-mission-card about-mission-card--vision">
          <div class="about-mission-card__icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M4 24s7-14 20-14 20 14 20 14-7 14-20 14S4 24 4 24z" stroke="currentColor" stroke-width="2"/><circle cx="24" cy="24" r="7" stroke="currentColor" stroke-width="2"/><circle cx="24" cy="24" r="3" fill="currentColor" opacity="0.3"/></svg>
          </div>
          <h3>Tầm nhìn</h3>
          <p>
            Swim For Life hướng đến mục tiêu trở thành <strong>trung tâm đào tạo bơi lội hàng đầu Việt Nam</strong>, mở rộng mạng lưới 
            hoạt động trên toàn quốc. Chúng tôi mong muốn mỗi gia đình Việt Nam đều nhận thức được tầm quan trọng của kỹ năng bơi lội, 
            và mỗi đứa trẻ đều được học bơi đúng cách, an toàn, bài bản.
          </p>
          <p>
            Trong tầm nhìn dài hạn, Swim For Life đặt mục tiêu không chỉ dạy bơi mà còn xây dựng một hệ sinh thái thể thao dưới nước toàn diện, 
            bao gồm đào tạo vận động viên nghiệp dư, tổ chức các giải đấu bơi lội cộng đồng, và phối hợp với các tổ chức xã hội trong công tác 
            phòng chống đuối nước trên quy mô toàn quốc.
          </p>
          <div class="about-mission-stat-highlight">
            <span class="about-mission-stat-highlight__number">88%</span>
            <span class="about-mission-stat-highlight__text">Giảm nguy cơ đuối nước khi trẻ được trang bị kỹ năng bơi từ sớm <em>(Nguồn: UNICEF)</em></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ GIÁM ĐỐC ============ -->
  <section class="about-section" id="giam-doc">
    <div class="container">
      <div class="about-section-header reveal">
        <span class="about-section-badge">👤 Người Sáng Lập</span>
        <h2 class="about-section-title">Giám Đốc Nguyễn Huy Mạnh - Người Sáng Lập Swim For Life</h2>
      </div>

      <div class="about-founder reveal">
        <div class="about-founder__media">
          <YouTubeVideo
            videoId="b4B7GfHEsuk"
            poster="/images/team/thay-nguyen-huy-manh-2.png"
            alt="Thầy Nguyễn Huy Mạnh - Giám đốc sáng lập Trung tâm dạy bơi Swim For Life Việt Nam, tốt nghiệp Đại học Sư phạm Hà Nội"
            width={400}
            height={500}
          />
          <p class="about-founder__caption">
            Thầy Nguyễn Huy Mạnh — Giám đốc Swim For Life
          </p>
        </div>

        <div class="about-founder__content">
          <div class="about-founder__intro">
            <p>
              <strong>Thầy Nguyễn Huy Mạnh</strong> là người sáng lập và hiện giữ vai trò Giám đốc điều hành Trung tâm dạy bơi 
              Swim For Life Việt Nam. Tốt nghiệp <strong>Đại học Sư phạm Hà Nội</strong> - ngôi trường đào tạo sư phạm hàng đầu Việt Nam, 
              thầy Mạnh sở hữu nền tảng giáo dục vững chắc cùng phương pháp sư phạm khoa học, hiệu quả.
            </p>
            <p>
              Với hơn <strong>10 năm kinh nghiệm</strong> trong lĩnh vực đào tạo bơi lội, thầy Mạnh đã trực tiếp đào tạo và giám sát 
              hàng nghìn học viên từ trẻ em đến người lớn. Thầy nổi tiếng với phong cách giảng dạy kiên nhẫn, tận tâm, luôn đặt sự an toàn 
              và tiến bộ của học viên lên hàng đầu.
            </p>
          </div>

          <!-- Founder Tags -->
          <div class="about-founder__tags">
            <span class="about-founder__tag">🎓 ĐH Sư phạm Hà Nội</span>
