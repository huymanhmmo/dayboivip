  { id: 'chon-do-boi-hoc-sinh-nam', text: '3. Kinh nghiệm chọn đồ bơi học sinh nam thoải mái, năng động' },
  { id: 'chon-do-boi-hoc-sinh-nu', text: '4. Kinh nghiệm chọn đồ bơi học sinh nữ kín đáo, an toàn' },
  { id: 'chat-lieu-thun-co-gian-chong-clo', text: '5. Lựa chọn chất liệu thun co giãn 4 chiều bền bỉ và chống Clo' },
  { id: 'phoi-do-boi-di-hoc-phu-kien', text: '6. Cách phối đồ bơi đi học và các phụ kiện đi kèm' },
  { id: 'top-mau-do-boi-hoc-sinh-yeu-thich', text: '7. Top 5 mẫu đồ bơi học sinh được yêu thích nhất hiện nay' },
  { id: 'so-sanh-do-boi-tieu-hoc-trung-hoc', text: '8. So sánh đồ bơi học sinh tiểu học vs trung học' },
  { id: 'cach-bao-quan-do-boi-ben-dep', text: '9. Cách bảo quản đồ bơi chống sờn rách hiệu quả' },
  { id: 'dia-chi-mua-do-boi-uy-tin', text: '10. Địa chỉ mua đồ bơi học sinh uy tín, giá hợp lý' },
  { id: 'loi-khuyen-bao-ve-da-hlv-manh', text: '11. Lời khuyên an toàn và bảo vệ da cho bé từ HLV Nguyễn Huy Mạnh' },
  { id: 'faq-do-boi-hoc-sinh', text: '12. Câu hỏi thường gặp về đồ bơi học sinh (FAQ)' }
