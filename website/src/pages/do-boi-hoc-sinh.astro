      "@type": "ImageObject",
      "url": "https://dayboi.vip/images/logo/swim-for-life-logo.png"
    }
  },
  "datePublished": "2026-05-25",
  "dateModified": "2026-05-25",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://dayboi.vip/${post.slug}/`
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Nên chọn đồ bơi học sinh liền thân hay hai mảnh cho bé gái đi học bơi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Đối với các bé gái tham gia các tiết học bơi học đường, ba mẹ nên ưu tiên chọn đồ bơi học sinh liền thân (one-piece) hoặc bộ bơi rời tay dài kết hợp quần bơi lửng. Kiểu dáng này vừa đảm bảo tính kín đáo, lịch sự theo đúng quy định trường học, vừa giúp giữ ấm cơ thể hiệu quả và giảm thiểu lực cản của nước khi tập luyện kỹ năng bơi."
      }
    },
    {
      "@type": "Question",
      "name": "Làm thế nào để chọn size đồ bơi học sinh vừa vặn và thoải mái nhất?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Khi chọn size đồ bơi cho học sinh, phụ huynh nên dựa trên chiều cao và cân nặng thực tế thay vì chỉ nhìn vào độ tuổi hay size quần áo thông thường của bé. Một bộ đồ bơi chuẩn phải ôm sát cơ thể vừa vặn nhưng không gây ra các vết hằn đỏ trên da vai hay bẹn đùi. Phụ huynh nên chọn chất liệu thun co giãn tốt và để bé thử mặc, giơ cao tay hoặc ngồi xuống xem có bị kích hay chật không."
      }
    },
    {
      "@type": "Question",
      "name": "Tại sao chất liệu vải chống Clo lại quan trọng đối với đồ bơi học sinh?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Hóa chất Clo khử trùng trong nước bể bơi trường học hay các trung tâm dạy bơi là nguyên nhân chính làm đứt gãy sợi vải Spandex thông thường, khiến đồ bơi bị giãn nhão, sờn rách và phai màu nhanh chóng. Việc chọn chất liệu vải có tính năng chống Clo vượt trội sẽ giúp tăng độ bền của trang phục gấp 5 - 10 lần, tiết kiệm chi phí mua sắm đồ bơi mới cho phụ huynh."
      }
    },
    {
      "@type": "Question",
      "name": "Học sinh có được mặc quần đùi thông thường hoặc áo thun cotton để xuống bể bơi không?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tuyệt đối không nên mặc quần đùi thông thường hay áo thun cotton khi xuống bể bơi học đường. Chất liệu cotton có khả năng thấm hút nước cực mạnh, khiến trang phục nặng nề, tạo lực cản của nước rất lớn, gây cản trở động tác bơi và tăng nguy cơ đuối nước do kiệt sức. Ngoài ra, sợi bông cotton dễ mủn ra làm nghẹt hệ thống lọc nước của hồ bơi và bị cấm theo nội quy của hầu hết các bể bơi học đường."
      }
    },
    {
      "@type": "Question",
      "name": "Có cần trang bị mũ bơi và kính bơi cho học sinh khi đi học bơi ở trường không?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Đây là những phụ kiện bắt buộc đi kèm cùng đồ bơi học sinh. Kính bơi bảo vệ mắt trẻ khỏi hóa chất Clo gây đỏ mắt, viêm kết mạc và giúp bé tự tin mở mắt định vị dưới nước. Mũ bơi giúp gom gọn tóc, tránh tóc xòa vào mắt, mũi, miệng cản trở việc thở nước và đồng thời giữ ấm vùng đầu khi bơi thời gian dài."
      }
    }
  ]
};

const tocItems = [
