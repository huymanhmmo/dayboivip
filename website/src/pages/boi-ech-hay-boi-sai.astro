---
import BlogLayout from '../layouts/BlogLayout.astro';
import { blogPosts } from '../data/blogPosts.js';

const post = blogPosts.find((p) => p.slug === 'boi-ech-hay-boi-sai');

if (!post) {
  throw new Error('Post not found in blogPosts.js');
}

const breadcrumbs = [
  { label: 'Trang chủ', href: '/' },
  { label: 'Tin tức', href: '/tin-tuc/' },
  { label: post.category, href: `/tin-tuc/${post.categorySlug}/` },
  { label: post.title },
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.excerpt,
  "image": `https://dayboi.vip${post.image}`,
  "author": {
    "@type": "Person",
    "name": "Thầy Nguyễn Huy Mạnh",
    "jobTitle": "Giám đốc đào tạo",
    "url": "https://dayboi.vip/#founder"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Swim For Life Việt Nam",
    "logo": {
      "@type": "ImageObject",
      "url": "https://dayboi.vip/images/logo/swim-for-life-logo.png"
    }
  },
  "datePublished": "2026-05-24",
  "dateModified": "2026-05-24",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://dayboi.vip/${post.slug}/`
  }
};

const tocItems = [
  { id: 'tong-quan', text: '1. Tổng quan về bơi ếch và bơi sải' },
  { id: 'uu-diem-boi-ech', text: '2. Ưu điểm của bơi ếch' },
  { id: 'uu-diem-boi-sai', text: '3. Ưu điểm của bơi sải' },
  { id: 'loi-khuyen', text: '4. Nên học bơi ếch hay bơi sải trước?' }
];
---

<BlogLayout
  title={`${post.title} | Swim For Life Việt Nam`}
  description={post.excerpt}
  canonical={`https://dayboi.vip/${post.slug}/`}
  breadcrumbs={breadcrumbs}
  schema={articleSchema}
  category={post.category}
  readTime={post.readTime}
  publishDate={post.date}
  featuredImage={post.image}
  featuredImageAlt="Bơi ếch hay bơi sải"
  intro={post.excerpt}
  tocItems={tocItems}
>
  <h2 id="tong-quan">1. Tổng quan về bơi ếch và bơi sải</h2>
  <p>Nhiều người mới học bơi thường băn khoăn không biết nên chọn học kiểu <a href="/ky-thuat-boi/hoc-boi-ech/">bơi ếch</a> hay <a href="/ky-thuat-boi/hoc-boi-sai/">bơi sải</a> trước. Mỗi kiểu bơi đều có những ưu điểm, nhược điểm và kỹ thuật đặc trưng riêng. Hãy cùng phân tích để tìm ra câu trả lời phù hợp nhất cho bạn.</p>

  <h2 id="uu-diem-boi-ech">2. Ưu điểm của bơi ếch</h2>
  <ul>
    <li><strong>Dễ học cho người mới:</strong> Kỹ thuật bơi ếch đối xứng hai bên, dễ phối hợp tay chân, nhịp thở nhô đầu lên trên mặt nước giúp người học đỡ bị ngạt nước và sợ hãi.</li>
    <li><strong>Giữ tầm nhìn tốt:</strong> Vì đầu ngẩng lên tự nhiên trong quá trình thở, bạn dễ dàng quan sát xung quanh, thích hợp cho bơi ở những nơi đông người hoặc bơi ngoài tự nhiên (sông, hồ, biển).</li>
    <li><strong>Tiết kiệm sức:</strong> Bơi ếch có thể bơi chậm, có những nhịp nghỉ dài (lướt nước), giúp bơi được lâu mà không quá mệt mỏi.</li>
  </ul>

  <h2 id="uu-diem-boi-sai">3. Ưu điểm của bơi sải</h2>
  <ul>
    <li><strong>Tốc độ nhanh nhất:</strong> Trong các kiểu bơi thể thao, bơi sải là kiểu bơi có tốc độ nhanh nhất nhờ lực cản nhỏ nhất.</li>
    <li><strong>Tiêu thụ nhiều calo:</strong> Bơi sải đòi hỏi vận động liên tục với cường độ cao, giúp đốt cháy lượng calo lớn, rất tốt cho quá trình giảm cân.</li>
    <li><strong>Tốt cho xương khớp:</strong> Bơi sải giúp kéo giãn cơ thể liên tục, giảm áp lực lên cột sống, rất tốt cho người gặp vấn đề về xương khớp.</li>
  </ul>

  <h2 id="loi-khuyen">4. Nên học bơi ếch hay bơi sải trước?</h2>
  <p>Tại Swim For Life Việt Nam, chúng tôi thường khuyên người mới bắt đầu nên <strong>học bơi ếch trước</strong>, vì những lý do sau:</p>
  <ol>
    <li>Bơi ếch giúp bạn nhanh chóng có cảm giác an toàn, quen thuộc với môi trường nước, giảm cảm giác sợ nước nhờ việc có thể quan sát xung quanh dễ dàng.</li>
    <li>Kỹ thuật bơi ếch giúp xây dựng nhịp thở cơ bản dưới nước (thở ra bằng mũi dưới nước, hít vào bằng miệng khi ngẩng đầu lên) một cách dễ dàng và tự nhiên nhất.</li>
    <li>Sau khi đã thành thạo bơi ếch và nhịp thở dưới nước, việc chuyển sang học bơi sải (đòi hỏi kỹ thuật xoay đầu lấy hơi phức tạp hơn) sẽ trở nên nhẹ nhàng hơn rất nhiều.</li>
  </ol>

  <p>Tất nhiên, nếu bạn đã không còn sợ nước và có nền tảng thể lực tốt, bạn hoàn toàn có thể chọn học bơi sải trước.</p>

  <div class="cta-banner" style="margin: var(--space-8) 0; border-radius: var(--radius-xl);">
    <h2>Bắt đầu hành trình bơi lội của bạn</h2>
    <p>Dù là bơi ếch hay bơi sải, Swim For Life đều có khóa học phù hợp với cam kết 100% biết bơi sau 1 khóa học.</p>
    <div class="btn-group">
      <a href="/khoa-hoc-boi/" class="btn btn-accent btn-lg">Xem Khóa Học</a>
      <a href="/lien-he/" class="btn btn-white btn-lg">Đăng Ký Học Thử</a>
    </div>
  </div>
</BlogLayout>
