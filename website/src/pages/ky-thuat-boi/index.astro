<script>
  // FAQ Accordion Toggle
  const setupFAQ = () => {
    const faqItems = document.querySelectorAll('.tl-faq__item');
    faqItems.forEach(item => {
      const button = item.querySelector('.tl-faq__question');
      if (button) {
        button.addEventListener('click', () => {
          const isActive = item.classList.contains('active');
          
          // Close all
          faqItems.forEach(i => {
            i.classList.remove('active');
            i.querySelector('.tl-faq__question')?.setAttribute('aria-expanded', 'false');
          });
          
          if (!isActive) {
            item.classList.add('active');
            button.setAttribute('aria-expanded', 'true');
          }
        });
      }
    });
  };

  // Reading Progress Indicator
  const setupReadingProgress = () => {
    const progressBar = document.getElementById('reading-progress');
    if (!progressBar) return;
    
    const updateProgress = () => {
      const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      if (scrollHeight <= 0) return;
      const scrollPosition = window.scrollY;
      const progressPercent = Math.min(100, Math.max(0, (scrollPosition / scrollHeight) * 100));
      progressBar.style.width = `${progressPercent}%`;
    };
    
    window.addEventListener('scroll', updateProgress);
    window.addEventListener('resize', updateProgress);
    updateProgress();
  };

  // Swimmer Anatomy Interactive Widget
  const setupAnatomyWidget = () => {
    const scriptEl = document.getElementById('anatomy-data-script');
    if (!scriptEl) return;
    
    let data: any;
    try {
      data = JSON.parse(scriptEl.textContent || '{}');
    } catch (e) {
      console.error("Failed to parse anatomy data", e);
      return;
    }
    
    const hotspots = document.querySelectorAll('.tl-anatomy__hotspot');
    const selectBtns = document.querySelectorAll('.tl-anatomy__select-btn');
    
    const iconEl = document.getElementById('anatomy-icon');
    const titleEl = document.getElementById('anatomy-title');
    const subtitleEl = document.getElementById('anatomy-subtitle');
    const descEl = document.getElementById('anatomy-desc');
    
    if (!iconEl || !titleEl || !subtitleEl || !descEl) return;
    
    const updateDisplay = (part: string) => {
      const partData = data[part];
      if (!partData) return;
      
      // Update text with transition effect
      const card = document.querySelector('.tl-anatomy__card');
      if (card) {
        card.classList.add('tl-updating');
        setTimeout(() => {
          iconEl.textContent = partData.icon || '💡';
          titleEl.textContent = partData.title || '';
          subtitleEl.textContent = partData.subtitle || '';
          descEl.textContent = partData.desc || '';
          card.classList.remove('tl-updating');
        }, 150);
      } else {
        iconEl.textContent = partData.icon || '💡';
        titleEl.textContent = partData.title || '';
        subtitleEl.textContent = partData.subtitle || '';
        descEl.textContent = partData.desc || '';
      }
      
      // Update hotspots active state
      hotspots.forEach(h => {
        if (h.getAttribute('data-part') === part) {
          h.classList.add('active');
        } else {
          h.classList.remove('active');
        }
      });
      
      // Update selector buttons active state
      selectBtns.forEach(b => {
        if (b.getAttribute('data-part') === part) {
          b.classList.add('active');
        } else {
          b.classList.remove('active');
        }
      });
    };
    
    // Add event listeners for hotspots
    hotspots.forEach(h => {
      const part = h.getAttribute('data-part');
      if (!part) return;
      
      h.addEventListener('click', (e) => {
        e.preventDefault();
        updateDisplay(part);
      });
      
      h.addEventListener('mouseenter', () => {
        updateDisplay(part);
      });
    });
    
    // Add event listeners for selection buttons (mobile selectors)
    selectBtns.forEach(b => {
      const part = b.getAttribute('data-part');
      if (!part) return;
      
      b.addEventListener('click', (e) => {
        e.preventDefault();
        updateDisplay(part);
      });
    });
  };

  // Run immediately and on DOMContentLoaded
  setupFAQ();
  setupReadingProgress();
  setupAnatomyWidget();
  
  document.addEventListener('DOMContentLoaded', () => {
    setupFAQ();
    setupReadingProgress();
    setupAnatomyWidget();
  });
</script>
