---
import BlogLayout from '../layouts/BlogLayout.astro';
import { blogPosts } from '../data/blogPosts.js';

const post = blogPosts.find((p) => p.slug === 'lop-hoc-boi');

if (!post) {
  throw new Error('Post not found in blogPosts.js');
}

const breadcrumbs = [
  { label: 'Trang chủ', href: '/' },
  { label: 'Tin tức', href: '/tin-tuc/' },
  { label: post.category, href: `/${post.categorySlug}/` },
  { label: post.title },
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.excerpt,
  "image": `https://dayboi.vip${post.image}`,
  "author": {
    "@type": "Person",
    "name": "Nguyễn Huy Mạnh",
    "jobTitle": "Giám đốc đào tạo",
    "url": "https://dayboi.vip/#founder"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Swim For Life Việt Nam",
    "logo": {
      "@type": "ImageObject",
      "url": "https://dayboi.vip/images/logo/swim-for-life-logo.png"
    }
  },
  "datePublished": "2026-05-25",
  "dateModified": "2026-05-25",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://dayboi.vip/${post.slug}/`
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Lớp học bơi 1 kèm 1 và lớp nhóm, nên chọn hình thức nào?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Lớp 1 kèm 1 phù hợp với người sợ nước, cần tiến bộ nhanh hoặc lịch trình bận rộn. Lớp nhóm nhỏ (3-5 người) phù hợp với trẻ em cần môi trường tương tác và người lớn muốn tiết kiệm chi phí. Tại Swim For Life, lớp 1 kèm 1 cam kết biết bơi sau 7-10 buổi, lớp nhóm sau 10-15 buổi."
      }
    },
    {
      "@type": "Question",
      "name": "Học phí lớp học bơi hiện nay dao động bao nhiêu?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Học phí lớp bơi dao động từ 800.000đ - 5.000.000đ/khóa tùy hình thức. Lớp nhóm lớn khoảng 800.000 - 1.500.000đ, nhóm nhỏ 1.500.000 - 2.500.000đ, và lớp 1 kèm 1 từ 2.500.000 - 5.000.000đ cho trọn khóa 10-12 buổi."
      }
    },
    {
      "@type": "Question",
      "name": "Trẻ em mấy tuổi có thể bắt đầu đi học bơi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Trẻ từ 4 tuổi trở lên có thể bắt đầu học bơi bài bản. Độ tuổi vàng để học bơi hiệu quả nhất là 5-8 tuổi, khi hệ thần kinh vận động đã phát triển đủ để tiếp thu kỹ thuật. Một số trung tâm có lớp làm quen nước cho bé từ 3 tuổi."
      }
    },
    {
      "@type": "Question",
      "name": "Người lớn chưa biết bơi thì mất bao lâu để biết bơi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Người lớn chưa biết bơi thường mất 10-15 buổi để biết bơi cơ bản kiểu ếch. Với lớp 1 kèm 1, thời gian rút ngắn còn 7-10 buổi. Người có tâm lý sợ nước nặng có thể cần thêm 3-5 buổi làm quen nước trước khi vào lộ trình chính."
      }
    },
    {
      "@type": "Question",
      "name": "Lớp học bơi có cam kết biết bơi không? Nếu không biết bơi thì sao?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Các trung tâm uy tín như Swim For Life cam kết biết bơi 100% sau một khóa học. Nếu hết khóa mà học viên chưa đạt yêu cầu, trung tâm sẽ dạy thêm miễn phí cho đến khi biết bơi. Tuy nhiên, cam kết này chỉ áp dụng khi học viên tham gia đầy đủ các buổi học."
      }
    },
    {
      "@type": "Question",
      "name": "Lớp bơi mùa đông có hoạt động không? Bể nóng có an toàn?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nhiều trung tâm duy trì lớp bơi quanh năm với hệ thống bể nóng (nước 30-32°C). Bể nóng hoàn toàn an toàn và được kiểm soát nhiệt độ tự động. Mùa đông thực tế là thời điểm tốt để học bơi vì bể bơi vắng hơn, HLV có thể dành nhiều thời gian hơn cho từng học viên."
      }
    },
    {
      "@type": "Question",
      "name": "Làm sao phân biệt lớp bơi uy tín và lớp bơi kém chất lượng?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Lớp bơi uy tín có: HLV có bằng cấp chuyên môn, giáo trình rõ ràng, sĩ số không quá 5 học viên/lớp nhóm, cam kết biết bơi bằng văn bản, bể bơi đạt chuẩn vệ sinh. Cảnh giác với lớp quảng cáo giá rẻ bất thường, không có thông tin HLV, hoặc nhồi quá 10 học viên/lớp."
      }
    }
  ]
};

const tocItems = [
  { id: 'lop-hoc-boi-la-gi', text: '1. Lớp học bơi là gì? Tổng quan các loại lớp hiện nay' },
  { id: 'lop-boi-tre-em-vs-nguoi-lon', text: '2. Lớp bơi cho trẻ em và người lớn khác nhau thế nào?' },
  { id: 'so-sanh-1-kem-1-vs-nhom', text: '3. So sánh lớp 1 kèm 1 vs nhóm nhỏ vs nhóm lớn' },
  { id: 'tieu-chi-chon-lop', text: '4. Tiêu chí nào giúp chọn được lớp bơi uy tín?' },
  { id: 'lop-boi-theo-mua', text: '5. Lớp bơi theo mùa: Hè, đông và quanh năm' },
  { id: 'lop-boi-sinh-ton', text: '6. Lớp bơi sinh tồn và cấp chứng chỉ bơi' },
  { id: 'bang-gia-tham-khao', text: '7. Bảng giá lớp học bơi tham khảo 2026' },
  { id: 'lop-boi-ha-noi', text: '8. Lớp học bơi tại Hà Nội: Nên học ở đâu?' },
  { id: 'lop-boi-tphcm', text: '9. Lớp học bơi tại TPHCM: Địa chỉ nào tốt?' },
  { id: 'quy-trinh-dang-ky', text: '10. Quy trình đăng ký lớp bơi diễn ra như thế nào?' },
  { id: 'sai-lam-chon-lop', text: '11. Những sai lầm phổ biến khi chọn lớp học bơi' },
  { id: 'faq', text: '12. Câu hỏi thường gặp (FAQ)' },
