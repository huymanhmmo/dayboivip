---
import CourseLayout from '../../layouts/CourseLayout.astro';
import { nguoiCaoTuoi } from '../../data/courses.js';

const breadcrumbs = [
  { label: 'Trang chủ', href: '/' },
  { label: 'Khóa học bơi', href: '/khoa-hoc-boi/' },
  { label: 'Người cao tuổi' },
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Học Bơi Người Cao Tuổi: Lớp Học Bơi Cho Người Lớn Tuổi Bảo Vệ Xương Khớp",
  "description": "Lớp học bơi chuyên biệt dành cho người cao tuổi, người lớn tuổi tại Swim For Life. Giáo trình nhẹ nhàng giúp giảm đau xương khớp, nâng cao tim mạch và ngủ ngon.",
  "author": {
    "@type": "Person",
    "name": "Thầy Nguyễn Huy Mạnh",
    "jobTitle": "Giám đốc đào tạo",
    "affiliation": {
      "@type": "Organization",
      "name": "Swim For Life Việt Nam"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Swim For Life Việt Nam",
    "logo": {
      "@type": "ImageObject",
      "url": "https://dayboi.vip/images/logo/swim-for-life-logo.png"
    }
  },
  "datePublished": "2026-02-10",
  "dateModified": "2026-05-21",
  "image": "https://dayboi.vip/images/classes/giao-vien-ho-tro-tan-tam.jpg",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://dayboi.vip/khoa-hoc-boi/nguoi-cao-tuoi/"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Người cao tuổi xương khớp yếu có học bơi được không?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Hoàn toàn được và rất nên học. Trong môi trường nước, nhờ lực nâng Archimedes, 90% trọng lượng cơ thể được nâng đỡ, giảm áp lực tối đa lên các khớp gối, cột sống và hông. Bơi lội là môn thể thao an toàn nhất cho người lớn tuổi gặp các vấn đề về thoái hóa khớp."
      }
    },
    {
      "@type": "Question",
      "name": "Giáo trình dạy bơi cho người lớn tuổi khác gì lớp bình thường?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Lớp học bơi người cao tuổi tại Swim For Life được thiết kế với nhịp độ rất chậm, chú trọng khởi động kỹ, tập các động tác thả lỏng cơ thể. Chúng tôi ưu tiên các bài tập thở giúp tăng dung tích phổi và kỹ thuật bơi ếch/bơi ngửa nhẹ nhàng, không đòi hỏi sức bền quá lớn."
      }
    },
    {
      "@type": "Question",
      "name": "Nước bể bơi có đủ ấm cho người già không?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Swim For Life luôn lựa chọn các bể bơi bốn mùa có hệ thống gia nhiệt tự động, duy trì nhiệt độ nước ổn định từ 28 - 30 độ C. Nước ấm giúp điều hòa huyết áp, giãn nở mạch máu và giữ ấm cơ thể cho người lớn tuổi suốt buổi học."
      }
    }
  ]
};

const combinedSchema = [articleSchema, faqSchema];
---

<CourseLayout
  course={nguoiCaoTuoi}
  breadcrumbs={breadcrumbs}
  schema={combinedSchema}
/>
