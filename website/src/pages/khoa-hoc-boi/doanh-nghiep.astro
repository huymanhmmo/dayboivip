---
import CourseLayout from '../../layouts/CourseLayout.astro';
import { doanhNghiep } from '../../data/courses.js';

const breadcrumbs = [
  { label: 'Trang chủ', href: '/' },
  { label: 'Khóa học bơi', href: '/khoa-hoc-boi/' },
  { label: 'Doanh nghiệp & Vinhomes' },
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Dạy Bơi Doanh Nghiệp & Vinhomes: Chương Trình Đào Tạo Chuyên Biệt",
  "description": "Chương trình dạy bơi cho doanh nghiệp, trường học và các khu đô thị Vinhomes. Tổ chức giải bơi chuyên nghiệp, dạy bơi miễn phí cho cư dân Vinhomes cùng Swim For Life.",
  "author": {
    "@type": "Person",
    "name": "Thầy Nguyễn Huy Mạnh",
    "jobTitle": "Giám đốc đào tạo",
    "affiliation": {
      "@type": "Organization",
      "name": "Swim For Life Việt Nam"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Swim For Life Việt Nam",
    "logo": {
      "@type": "ImageObject",
      "url": "https://dayboi.vip/images/logo/swim-for-life-logo.png"
    }
  },
  "datePublished": "2026-02-20",
  "dateModified": "2026-05-21",
  "image": "https://dayboi.vip/images/classes/to-chuc-bai-ban-chuyen-nghiep.jpg",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://dayboi.vip/khoa-hoc-boi/doanh-nghiep/"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Quy mô tối thiểu để đăng ký khóa học bơi doanh nghiệp là bao nhiêu?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Swim For Life nhận đào tạo cho các đoàn thể, doanh nghiệp từ 10 học viên trở lên. Chúng tôi sẽ thiết kế giáo án riêng, bố trí số lượng HLV phù hợp để đảm bảo chất lượng giảng dạy và an toàn tốt nhất cho đoàn."
      }
    },
    {
      "@type": "Question",
      "name": "Lớp học bơi miễn phí Vinhomes dành cho đối tượng nào?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Đây là chương trình hợp tác đặc biệt giữa Ban quản lý Vinhomes và Swim For Life Việt Nam, dành riêng cho cư dân nhí (từ 4-15 tuổi) đang sinh sống tại các khu đô thị của Vinhomes như Times City, Royal City, Ocean Park, Smart City, Grand Park..."
      }
    },
    {
      "@type": "Question",
      "name": "Trung tâm có hỗ trợ tổ chức giải bơi nội bộ không?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Có. Swim For Life có dịch vụ trọn gói tổ chức giải bơi lội phong trào cho doanh nghiệp, trường học và khu dân cư bao gồm: lập điều lệ giải, trọng tài chuyên nghiệp, cứu hộ, thiết bị bấm giờ, âm thanh, ánh sáng và trao giải thưởng."
      }
    }
  ]
};

const combinedSchema = [articleSchema, faqSchema];
---

<CourseLayout
  course={doanhNghiep}
  breadcrumbs={breadcrumbs}
  schema={combinedSchema}
/>
