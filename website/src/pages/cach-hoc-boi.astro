  { id: 'chuan-bi-truoc-khi-boi', text: '2. Chuẩn bị trước khi bơi: Hành trang không thể thiếu' },
  { id: 'dung-cu-hoc-boi', text: '3. Phân loại dụng cụ học bơi: Kính bơi, phao bơi, đồ bơi' },
  { id: 'khoi-dong-tren-can', text: '4. Khởi động trên cạn: Nghi thức bắt buộc' },
  { id: 'tam-ly-so-nuoc', text: '5. Vượt qua tâm lý sợ nước ở người lớn' },
  { id: 'lam-quen-voi-nuoc', text: '6. Bước 1: Làm quen với nước ở khu vực nông' },
  { id: 'tap-tho-duoi-nuoc', text: '7. Bước 2: Kỹ năng sống còn - Tập thở dưới nước' },
  { id: 'noi-sap-tren-mat-nuoc', text: '8. Bước 3: Nổi sấp trên mặt nước (Bài tập phi tiêu)' },
  { id: 'bai-tap-luot-nuoc', text: '9. Bước 4: Bài tập lướt nước tạo cảm giác' },
  { id: 'dap-chan-ech', text: '10. Bước 5: Đạp chân ếch - Động cơ đẩy chính' },
  { id: 'quat-tay-ech', text: '11. Bước 6: Quạt tay ếch - Bánh lái định hướng' },
  { id: 'phoi-hop-dong-tac', text: '12. Bước 7: Phối hợp tay chân thở - Hoàn thiện kỹ thuật' },
  { id: 'ky-thuat-dung-nuoc', text: '13. Mở rộng: Kỹ thuật đứng nước và chống đuối nước' },
  { id: 'che-do-dinh-duong', text: '14. Chế độ dinh dưỡng cho người bơi' },
