      <a href="/khoa-hoc-boi/" class="btn btn-accent btn-lg">Xem Khóa Học</a>
      <a href="tel:0979121097" class="btn btn-white btn-lg">📞 Đăng Ký Ngay</a>
    </div>
  </div>
</BlogLayout>
